# === Database ===
DATABASE_URL=postgresql://rdo:rdo@localhost:5432/rdo_digital
REDIS_URL=redis://localhost:6379/0

# === Ollama (LLM local) ===
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
EMBEDDING_MODEL=qwen3-embedding:0.6b

# === OpenAI ===
OPENAI_API_KEY=sk-...

# === Whisper (STT) ===
# Modos: openai | groq | local
WHISPER_MODE=openai
WHISPER_API_KEY=        # opcional: usa OPENAI_API_KEY se vazio
GROQ_API_KEY=           # obrigatório se WHISPER_MODE=groq

# === Telegram ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=https://bot.seudominio.com

# === WhatsApp (Evolution API) ===
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=rdo-digital

# === Cloudflare Tunnel (VPS) ===
# Crie o tunnel: cloudflared tunnel create rdo-obra
# Roteie o domínio: cloudflared tunnel route dns rdo-obra bot.seudominio.com
CLOUDFLARE_TUNNEL_TOKEN=

# === Storage ===
UPLOAD_DIR=./uploads
OUTPUT_DIR=./output

# === Semantic search ===
SEMANTIC_MATCH_THRESHOLD=0.80
SEMANTIC_MATCH_MARGIN=0.05
STATE_TTL_HOURS_WHATSAPP=48
STATE_TTL_HOURS_TELEGRAM=24
STATE_TTL_HOURS_DEFAULT=24

# === App ===
DEBUG=false
TZ=America/Manaus
